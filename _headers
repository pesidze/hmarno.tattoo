# HTML — always revalidate so updates reach visitors immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/es/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Root pages served without .html extension
/
  Cache-Control: public, max-age=0, must-revalidate

/es/
  Cache-Control: public, max-age=0, must-revalidate

# Images — 1 year, immutable (filenames are unique per shoot)
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Sitemap and robots — revalidate weekly
/sitemap.xml
  Cache-Control: public, max-age=604800, must-revalidate

/robots.txt
  Cache-Control: public, max-age=604800, must-revalidate
